generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  username            String?              @unique
  passwordHash        String
  role                UserRole             @default(CUSTOMER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  profile             Profile?
  // Chat relations
  providedAssignments  OrderAssignment[]
  conversationMembers  ConversationParticipant[]
  sentMessages         Message[]
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id                String      @id @default(cuid())
  customerId        String
  serviceId         String
  status            OrderStatus @default(PENDING)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  boostType         String
  playMode          String?
  region            String?
  queueType         String?

  currentRank       String?
  currentLP         String?
  currentMasterLp   Int?
  desiredRank       String?
  desiredMasterLp   Int?
  lpGain            String?
  peakRank          String?
  desiredWins       Int?
  placementGames    Int?
  numberOfGames     Int?

  firstRole         String?
  secondRole        String?
  selectedChampions Json?

  priorityOrder     Boolean     @default(false)
  premiumCoaching   Boolean     @default(false)
  liveStream        Boolean     @default(false)
  appearOffline     Boolean     @default(false)
  bonusWin          Boolean     @default(false)
  soloOnly          Boolean     @default(false)
  highMMRDuo        Boolean     @default(false)

  basePrice         Float       @default(0)
  addonPrice        Float       @default(0)
  totalPrice        Float       @default(0)

  customer          User        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service           Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  // Chat / assignment back-relations
  assignments       OrderAssignment[]
  conversation      Conversation?
}

/// Link assigned boosters/providers to an order
model OrderAssignment {
  id        String   @id @default(cuid())
  orderId   String
  boosterId String
  createdAt DateTime @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  booster User  @relation(fields: [boosterId], references: [id], onDelete: Cascade)

  @@unique([orderId, boosterId])
  @@index([boosterId])
}

/// Conversation (thread) for chat, optionally tied to an order
model Conversation {
  id            String                   @id @default(cuid())
  orderId       String?                  @unique
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  lastMessageAt DateTime?                @default(now())

  order         Order?                   @relation(fields: [orderId], references: [id])
  participants  ConversationParticipant[]
  messages      Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  roleAtJoin     UserRole
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
